# ImitatorT 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ==================== Matrix Homeserver 配置 ====================

# Homeserver URL (Conduit 默认端口为 5141, Tuwunel 使用自定义端口)
MATRIX_HOMESERVER_URL=http://localhost:5141

# 服务器名称（与 Homeserver 配置的 server_name 一致）
MATRIX_SERVER_NAME=localhost

# ==================== Appservice 令牌 ====================
# 这些值必须与 registration.yaml 中的值一致

# Appservice Token (as_token)
MATRIX_AS_TOKEN=imitatort_as_token_CHANGE_THIS_IN_PRODUCTION

# Homeserver Token (hs_token)
MATRIX_HS_TOKEN=imitatort_hs_token_CHANGE_THIS_IN_PRODUCTION

# ==================== 虚拟用户配置 ====================

# Sender Localpart（可选，默认：_imitator_bot）
# 这是 Appservice 的默认虚拟用户 ID 前缀
MATRIX_SENDER_LOCALPART=_imitator_bot

# ==================== Appservice 服务器配置 ====================

# Appservice 监听端口（可选，默认：9000）
# Homeserver 会将事件推送到这个端口
MATRIX_APPSERVICE_PORT=9000

# ==================== LDAP 配置（可选） ====================
# 用于 LDAP (lldap) 用户和组织架构同步
# 当配置 LDAP 时，ImitatorT 会在启动时将 Agent 同步到 LDAP

# LDAP 服务器 URL
LDAP_URL=ldap://localhost:3890

# LDAP 基础 DN
LDAP_BASE_DN=dc=example,dc=com

# LDAP 绑定 DN（管理员）
LDAP_BIND_DN=cn=admin,ou=people,dc=example,dc=com

# LDAP 密码
LDAP_BIND_PASSWORD=your_password

# LDAP 用户基础 DN
LDAP_USER_BASE_DN=ou=people,dc=example,dc=com

# LDAP 组基础 DN
LDAP_GROUP_BASE_DN=ou=groups,dc=example,dc=com

# LDAP HTTP API 端口（lldap 默认 17170，用于 GraphQL 操作）
LDAP_HTTP_PORT=17170

# LDAP HTTP API 主机（用于 GraphQL 操作）
LDAP_HTTP_HOST=localhost

# ==================== 应用程序配置 ====================

# 输出模式：web 或 console
# 注意：Matrix 模式下此配置不影响 Matrix 集成
OUTPUT_MODE=console

# 是否运行 Agent 自主循环
RUN_AGENT_LOOPS=true

# 数据库路径
DB_PATH=imitatort.db

# ==================== LLM 配置 ====================

# OpenAI API Key
OPENAI_API_KEY=your-api-key

# OpenAI API Base URL (可选)
# OPENAI_API_BASE_URL=https://api.openai.com/v1
